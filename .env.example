# ===========================================
# Supabase Configuration
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ===========================================
# Storage Mode
# ===========================================
# local = 使用本地 runs/、training-data/、evaluation-data/
# cloud = 使用 Supabase Postgres + Supabase Storage
PROOFLOOP_STORAGE_MODE=local

# ===========================================
# Cloud Analysis Mode (仅 cloud 模式生效)
# ===========================================
# worker = 独立 Worker 执行真实 pipeline (推荐生产环境)
# inline-mvp = Vercel 内联模拟分析 (仅用于 Demo)
CLOUD_ANALYSIS_MODE=worker

# ===========================================
# Demo Mode
# ===========================================
PROOFLOOP_DEMO_KEY=

# ===========================================
# AI Provider - 主分析
# ===========================================
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# ===========================================
# AI Provider - 验证
# ===========================================
VALIDATION_AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_VALIDATION_MODEL=deepseek-v4-pro

# ===========================================
# Anthropic (可选)
# ===========================================
ANTHROPIC_API_KEY=

# ===========================================
# App Configuration
# ===========================================
APP_URL=http://localhost:3000

# ===========================================
# Validation Configuration
# ===========================================
VALIDATION_MODE=false
ENABLE_AUTO_VALIDATION=true
ENABLE_FIXTURE_GENERATION=false
